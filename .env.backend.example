# Backend - Variables de Entorno

## Supabase (automático en Edge Functions)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# =====================================================
# ASISTENCIA IA - Configuración multi-proveedor
# =====================================================

# Proveedor: openai | xai | mock
AI_PROVIDER=mock

# OpenAI (si AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...
AI_MODEL=gpt-4o-mini

# xAI/Grok (si AI_PROVIDER=xai)
XAI_API_KEY=xai-...
AI_MODEL=grok-4.3
AI_BASE_URL=https://api.x.ai/v1

# =====================================================
# CORREO ELECTRÓNICO - Resend
# =====================================================

RESEND_API_KEY=re_...
REPORT_FROM_EMAIL=informes@sicompatagonia.com
REPORT_FROM_NAME=SICOM Patagonia Ascensores
