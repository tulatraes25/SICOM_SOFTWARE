# =====================================================
# SICOM QR Ascensores - Variables de Entorno (Backend)
# =====================================================
# Estas variables van en Supabase Edge Functions (Settings > Edge Functions)

# Supabase (automático en Edge Functions)
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...

# OpenAI (para generación de informes con IA)
OPENAI_API_KEY=sk-...
AI_MODEL=gpt-4o-mini

# Resend (para envío de correos)
RESEND_API_KEY=re_...
REPORT_FROM_EMAIL=informes@sicompatagonia.com
REPORT_FROM_NAME=SICOM Patagonia SRL
